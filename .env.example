# Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# JWT Configuration
JWT_SECRET=your-super-secret-key-that-is-at-least-32-characters-long-for-HS256
JWT_ISSUER=YourAppIssuer
JWT_AUDIENCE=YourAppAudience

# Catalog Database
CATALOG_DB_USER=postgres
CATALOG_DB_PASSWORD=postgres

# Identity Database
IDENTITY_DB_USER=postgres
IDENTITY_DB_PASSWORD=postgres

# Orders Database
ORDERS_DB_USER=postgres
ORDERS_DB_PASSWORD=postgres

# Application Ports (if you need to change from defaults)
# CATALOG_SERVICE_PORT=5001
# IDENTITY_SERVICE_PORT=5002
# ORDERS_SERVICE_PORT=5003
# CATALOG_DB_PORT=5432
# IDENTITY_DB_PORT=5433
# ORDERS_DB_PORT=5434

